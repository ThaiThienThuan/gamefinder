{
  "mongo": {
    "uri": "mongodb://mongo:27017/gamematch"
  },
  "server": {
    "port": 4000,
    "nodeEnv": "development",
    "logLevel": "dev"
  },
  "jwt": {
    "secret": "your-jwt-secret-min-32-chars-change-in-prod",
    "expiry": "7d"
  },
  "upload": {
    "maxFileSizeMB": 50,
    "uploadDir": "./uploads",
    "mimeWhitelist": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "video/mp4",
      "video/webm"
    ]
  },
  "cors": {
    "allowedOrigin": "http://localhost:3000"
  },
  "redis": {
    "host": "redis",
    "port": 6379,
    "password": null
  },
  "mediasoup": {
    "listenIp": "0.0.0.0",
    "announcedIp": "",
    "minPort": 30000,
    "maxPort": 30100
  },
  "turn": {
    "secret": "dev-turn-secret-change-in-production",
    "realm": "gamematch.local"
  }
}
