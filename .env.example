# MongoDB
MONGO_URI=mongodb://mongo:27017/gamematch

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-prod
JWT_EXPIRY=7d

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# CORS
ALLOWED_ORIGIN=http://localhost:3000

# Frontend (Vite)
VITE_API_URL=http://localhost:4000

# [REDIS_PLACEHOLDER — Phase C]
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=

# [MEDIASOUP_PLACEHOLDER — Phase D]
# TURN_SECRET=your-turn-secret-min-50-chars
# TURN_REALM=gamematch.local
# MEDIASOUP_LISTEN_IPS=127.0.0.1
# MEDIASOUP_ANNOUNCED_IP=
# MEDIASOUP_MIN_PORT=30000
# MEDIASOUP_MAX_PORT=30100
# MEDIASOUP_NETWORK_MODE=bridge
